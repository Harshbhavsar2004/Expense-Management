{
  "name": "adk-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:agent\" --names ui,agent --prefix-colors blue,green --kill-others",
    "dev:debug": "set LOG_LEVEL=debug && npm run dev",
    "dev:agent": "scripts\\run-agent.bat",
    "dev:ui": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "install:agent": "scripts\\setup-agent.bat",
    "postinstall": "npm run install:agent",
    "migrate:phones": "node scripts/migrate-phone-numbers.js",
    "verify:migration": "node scripts/migrate-phone-numbers.js verify"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.42",
    "@copilotkit/react-core": "^1.54.0",
    "@copilotkit/react-textarea": "^1.54.0",
    "@copilotkit/react-ui": "^1.54.0",
    "@copilotkit/runtime": "^1.54.0",
    "@heroui/react": "^3.0.0-beta.2",
    "@heroui/styles": "^3.0.0-beta.2",
    "@rive-app/react-canvas": "^4.27.3",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@syncfusion/ej2-react-kanban": "^33.1.44",
    "@tabler/icons-react": "^3.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "shiki": "^3.19.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
